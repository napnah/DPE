# Copy to .env on the VM (192.168.199.128) when running a full independent node.

DATABASE_URL=postgresql://dpe:dpe@localhost:5432/dpe
REDIS_URL=redis://localhost:6379

CONTROL_PLANE_PORT=3001
SIGNALING_PORT=3002
LAN_AGENT_PORT=3003

DPE_LAN_HOST=192.168.199.128

VITE_API_URL=http://192.168.199.128:3001
VITE_SIGNALING_URL=ws://192.168.199.128:3002/ws
VITE_LAN_AGENT_URL=http://192.168.199.128:3003

DPE_SIGNALING_URL=ws://192.168.199.128:3002/ws
DPE_PROXY_BASE_URL=http://192.168.199.128:3001

DPE_AGENT_HOST=192.168.199.128
DPE_AGENT_NAME=nap-virtual-machine

# VM probes Windows host when mDNS does not show host as neighbor:
DPE_DISCOVERY_PROBE_HOSTS=192.168.199.1

DPE_JWT_TTL_SEC=300
DPE_SIGNING_PRIVATE_KEY=
DPE_SIGNING_PUBLIC_KEY=
