DATABASE_URL=postgresql://dpe:dpe@localhost:5432/dpe
REDIS_URL=redis://localhost:6379
CONTROL_PLANE_PORT=3001
SIGNALING_PORT=3002
LAN_AGENT_PORT=3003
VITE_API_URL=http://localhost:3001
VITE_SIGNALING_URL=ws://localhost:3002/ws
# LAN / Host-Only: set to 1 to use host ICE + trickle:false (matches debug-p2p-user-flow.mjs)
# VITE_P2P_LAN=1
# P2P trace (off by default): set both to 1 to show diagnostic panel and collect events
# VITE_DPE_P2P_TRACE=1
# VITE_DPE_P2P_TRACE_UI=1
VITE_LAN_AGENT_URL=http://localhost:3003

# P3 — lan-agent / signaling (symmetric: each node runs signaling; mesh joins self + discovered peers)
DPE_NODE_ID=
# LAN IP for mDNS (dual-machine: e.g. 192.168.18.1); leave empty for auto-detect
DPE_AGENT_HOST=
DPE_AGENT_NAME=
DPE_MANUAL_PEERS=
# Comma-separated peer IPs to probe when mDNS is one-way (host: VM IP, VM: host IP)
DPE_DISCOVERY_PROBE_HOSTS=
DPE_MDNS_INTERFACE=
DPE_DISABLE_MDNS=
DPE_SIGNALING_URL=ws://localhost:3002/ws

# JWT lifetime for doc access tokens (seconds); default 300 = 5 minutes
DPE_JWT_TTL_SEC=300

# Control plane signing (base64url); generate via node -e "..." or leave empty for ephemeral
DPE_SIGNING_PRIVATE_KEY=
DPE_SIGNING_PUBLIC_KEY=
DPE_PROXY_BASE_URL=http://localhost:3001
