{
  "name": "@dpe/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx watch src/main.ts",
    "db:generate": "prisma generate",
    "db:generate:safe": "node scripts/stop-servers.mjs && prisma generate",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:push": "node scripts/run-prisma.mjs db push --skip-generate",
    "db:migrate": "node scripts/run-prisma.mjs migrate dev"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "@prisma/client": "^6.1.0",
    "@dpe/shared": "workspace:*",
    "@dpe/proto": "workspace:*",
    "@dpe/crypto": "workspace:*",
    "@dpe/acl": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "argon2": "^0.43.0",
    "reflect-metadata": "^0.2.2",
    "redis": "^4.7.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/express": "^5.0.0",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
