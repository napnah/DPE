# Copy to .env on the VM (Host-Only: 192.168.18.x, host signaling at 192.168.18.1).

DATABASE_URL=postgresql://dpe:dpe@localhost:5432/dpe
REDIS_URL=redis://localhost:6379

CONTROL_PLANE_PORT=3001
SIGNALING_PORT=3002
LAN_AGENT_PORT=3003

VITE_API_URL=http://192.168.18.128:3001
# Symmetric P2P: this VM runs its own signaling; mesh also joins peers via lan-agent discovery
VITE_SIGNALING_URL=ws://192.168.18.128:3002/ws
VITE_LAN_AGENT_URL=http://192.168.18.128:3003

DPE_NODE_ID=vm-nap-128
DPE_AGENT_HOST=192.168.18.128
DPE_AGENT_NAME=nap-virtual-machine
DPE_MANUAL_PEERS=
DPE_DISCOVERY_PROBE_HOSTS=192.168.18.1
DPE_MDNS_INTERFACE=192.168.18.128
DPE_DISABLE_MDNS=
DPE_SIGNALING_URL=ws://192.168.18.128:3002/ws

DPE_JWT_TTL_SEC=300
DPE_SIGNING_PRIVATE_KEY=
DPE_SIGNING_PUBLIC_KEY=
DPE_PROXY_BASE_URL=http://192.168.18.128:3001
