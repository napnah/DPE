# Copy to .env on the VM when running a full independent node (same layout as .env.example).

DATABASE_URL=postgresql://dpe:dpe@localhost:5432/dpe
REDIS_URL=redis://localhost:6379

CONTROL_PLANE_PORT=3001
SIGNALING_PORT=3002
LAN_AGENT_PORT=3003

VITE_API_URL=http://localhost:3001
VITE_SIGNALING_URL=ws://localhost:3002/ws
VITE_LAN_AGENT_URL=http://localhost:3003

# P3 - lan-agent / signaling
DPE_NODE_ID=
DPE_AGENT_HOST=
DPE_AGENT_NAME=nap-virtual-machine
DPE_MANUAL_PEERS=
# Comma-separated peer IPs for dual-host (e.g. host LAN IP); leave empty for localhost-only
DPE_DISCOVERY_PROBE_HOSTS=
DPE_MDNS_INTERFACE=
DPE_DISABLE_MDNS=
DPE_SIGNALING_URL=ws://localhost:3002/ws

DPE_JWT_TTL_SEC=300
DPE_SIGNING_PRIVATE_KEY=
DPE_SIGNING_PUBLIC_KEY=
DPE_PROXY_BASE_URL=http://localhost:3001
