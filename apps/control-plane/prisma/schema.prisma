generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id              String   @id @default(uuid())
  name            String
  description     String   @default("")
  ownerNodeId     String   @map("owner_node_id")
  ownerPublicKey  String   @map("owner_public_key")
  controlMode     String   @default("proxy") @map("control_mode")
  proxyNodeId     String?  @map("proxy_node_id")
  proxyPublicKey  String?  @map("proxy_public_key")
  proxyBaseUrl    String?  @map("proxy_base_url")
  issuerNodeId    String   @map("issuer_node_id")
  issuerPublicKey String   @map("issuer_public_key")
  createdAt       DateTime @default(now()) @map("created_at")

  members         Member[]
  invitations     Invitation[]
  docNodes        DocNode[]
  aclGrants       AclGrant[]
  groupRoles      GroupRole[]
  memberRoles     MemberRoleAssignment[]
  defaultRules    GroupDefaultRules?
  docRoleAcls     DocRoleAcl[]

  @@map("groups")
}

/// Named group role (管理员 / 协作者 / 读者 + custom).
model GroupRole {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  name      String
  slug      String
  color     String   @default("#0969da")
  sortOrder Int      @default(0) @map("sort_order")
  isBuiltin Boolean  @default(false) @map("is_builtin")

  group       Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignments MemberRoleAssignment[]
  docAcls     DocRoleAcl[]

  @@unique([groupId, slug])
  @@map("group_roles")
}

model MemberRoleAssignment {
  groupId String @map("group_id")
  nodeId  String @map("node_id")
  roleId  String @map("role_id")

  group Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  GroupRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, nodeId, roleId])
  @@map("member_role_assignments")
}

model GroupDefaultRules {
  groupId               String @id @map("group_id")
  defaultMemberRoleId   String @map("default_member_role_id")
  /// JSON map: roleId -> access level (0-3) for CreateChild template
  createChildTemplate   Json   @map("create_child_template")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_default_rules")
}

/// Per-document access level per group role (RBAC).
model DocRoleAcl {
  groupId      String @map("group_id")
  docId        String @map("doc_id")
  roleId       String @map("role_id")
  accessLevel  Int    @map("access_level")

  group Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  GroupRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, docId, roleId])
  @@map("doc_role_acls")
}

model Member {
  id          String    @id @default(uuid())
  groupId     String    @map("group_id")
  nodeId      String    @map("node_id")
  publicKey   String    @map("public_key")
  displayName String    @default("") @map("display_name")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  leftAt      DateTime? @map("left_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, nodeId])
  @@map("members")
}

model Invitation {
  id            String   @id @default(uuid())
  groupId       String   @map("group_id")
  inviterNodeId String   @map("inviter_node_id")
  inviteeNodeId String   @map("invitee_node_id")
  status        String   @default("pending")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([inviteeNodeId, status])
  @@map("group_invitations")
}

model DocNode {
  groupId     String   @map("group_id")
  docId       String   @map("doc_id")
  parentDocId String?  @map("parent_doc_id")
  title       String   @default("Untitled")
  isFolder    Boolean  @default(false) @map("is_folder")
  sortOrder   Int      @default(0) @map("sort_order")
  keyVersion  Int      @default(1) @map("key_version")
  createdAt   DateTime @default(now()) @map("created_at")

  group    Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  keys     DocumentKey[]
  snapshot DocSnapshot?
  state    DocState?

  @@id([groupId, docId])
  @@index([groupId, parentDocId])
  @@map("doc_nodes")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  displayName  String   @default("") @map("display_name")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  keys     UserKey[]
  sessions UserSession[]

  @@map("users")
}

model UserKey {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  nodeId            String   @unique @map("node_id")
  publicKey         String   @map("public_key")
  privateKeyCipher  String   @map("private_key_cipher") @db.Text
  keyEncryptSalt    String   @map("key_encrypt_salt")
  keyEncryptIv      String   @map("key_encrypt_iv")
  keyEncryptTag     String   @map("key_encrypt_tag")
  createdAt         DateTime @default(now()) @map("created_at")
  lastUsedAt        DateTime @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions UserSession[]

  @@index([userId])
  @@map("user_keys")
}

model UserSession {
  tokenHash  String   @id @map("token_hash")
  userId     String   @map("user_id")
  userKeyId  String   @map("user_key_id")
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  key  UserKey @relation(fields: [userKeyId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userKeyId])
  @@map("user_sessions")
}

/// DEV: latest Yjs encoded state for single-editor / offline reload (P2P remains authoritative for live merge).
model DocSnapshot {
  groupId         String   @map("group_id")
  docId           String   @map("doc_id")
  keyVersion      Int      @map("key_version")
  stateBase64     String   @map("state_base64") @db.Text
  updatedByNodeId String   @map("updated_by_node_id")
  updatedAt       DateTime @updatedAt @map("updated_at")

  doc DocNode @relation(fields: [groupId, docId], references: [groupId, docId], onDelete: Cascade)

  @@id([groupId, docId])
  @@map("doc_snapshots")
}

/// Canonical persisted Yjs state (database source of truth for snapshot API).
model DocState {
  groupId         String   @map("group_id")
  docId           String   @map("doc_id")
  keyVersion      Int      @map("key_version")
  stateBase64     String   @map("state_base64") @db.Text
  stateVectorBase64 String? @map("state_vector_base64") @db.Text
  updatedByNodeId String   @map("updated_by_node_id")
  updatedAt       DateTime @updatedAt @map("updated_at")

  doc DocNode @relation(fields: [groupId, docId], references: [groupId, docId], onDelete: Cascade)

  @@id([groupId, docId])
  @@map("doc_states")
}

/// DEV: server-side doc key material for issuing JWT (replace with HSM in production).
model DocumentKey {
  groupId    String @map("group_id")
  docId      String @map("doc_id")
  keyVersion Int    @map("key_version")
  keyBase64  String @map("key_base64")

  doc DocNode @relation(fields: [groupId, docId], references: [groupId, docId], onDelete: Cascade)

  @@id([groupId, docId, keyVersion])
  @@map("document_keys")
}

model AclGrant {
  groupId   String   @map("group_id")
  docId     String   @map("doc_id")
  nodeId    String   @map("node_id")
  role      Int
  updatedAt DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([groupId, docId, nodeId])
  @@map("acl_grants")
}

model JwtRevocation {
  jti       String   @id
  revokedAt DateTime @default(now()) @map("revoked_at")

  @@map("jwt_revocations")
}

model KeyRotationEvent {
  id         String   @id @default(uuid())
  groupId    String   @map("group_id")
  docId      String   @map("doc_id")
  keyVersion Int      @map("key_version")
  payloadJson String  @map("payload_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([groupId, docId])
  @@map("key_rotation_events")
}
